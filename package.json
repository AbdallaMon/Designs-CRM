{
  "name": "dms-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Design Management System — npm-workspaces monorepo (packages/db, packages/shared, server, ui).",
  "workspaces": [
    "packages/*",
    "server",
    "ui"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:server": "npm run dev -w server",
    "dev:ui": "npm run dev -w ui",
    "build:ui": "npm run build -w ui",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema packages/db/prisma/schema.prisma",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
